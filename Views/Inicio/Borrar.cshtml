@model CRUD.Models.Contacto

@{
    ViewData["Title"] = "Borrar Contacto";
}

<h1 class="text-center">Borrar Contacto</h1>

<div class="row">
    <div class="col-sm-12">
        <div class="card border">
            <div class="card-header bg-dark">
                <h3 class="text-white"><strong>¿Estás seguro de querer borrar este usuario?</strong></h3>
            </div>
            <div class="card-body">
                
                <form asp-action="Borrar">
                    
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mt-3">
                        <label asp-for="Nombre" class="control-label"></label>
                        <input asp-for="Nombre" class="form-control" readonly />
                    </div>

                    <div class="form-group mt-3">
                        <label asp-for="Telefono" class="control-label"></label>
                        <input asp-for="Telefono" class="form-control" readonly />
                    </div>

                    <div class="form-group mt-3">
                        <label asp-for="Celular" class="control-label"></label>
                        <input asp-for="Celular" class="form-control" readonly />
                    </div>

                    <div class="form-group mt-3">
                        <label asp-for="Email" class="control-label"></label>
                        <input asp-for="Email" class="form-control" readonly />
                    </div>

                    <div class="form-group mt-3">
                        <button type="submit" class="btn btn-danger d-block mx-auto w-100">
                            <i class="bi bi-eraser"></i> Borrar Usuario
                        </button>
                    </div>
                </form>

                <div class="mt-3">
                    <a asp-controller="Inicio" asp-action="Index" class="btn btn-dark">Volver</a>
                </div>

            </div>
        </div>
    </div>
</div>