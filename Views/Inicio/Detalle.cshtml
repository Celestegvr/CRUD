@model CRUD.Models.Contacto

@{
    ViewData["Title"] = "Detalle Contacto";
}

<h1 class="text-center">Detalle Contacto</h1>

<div class="row">
    <div class="col-sm-12">
        <div class="card border">
            <div class="card-header bg-dark">
                <h3 class="text-white"><strong>Detalle de Usuario</strong></h3>
            </div>
            <div class="card-body">
                
                <ul class="list-group">
                    <li class="list-group-item">
                        <strong>Nombre:</strong> @Html.DisplayFor(m => m.Nombre)
                    </li>
                    <li class="list-group-item">
                        <strong>Teléfono:</strong> @Html.DisplayFor(m => m.Telefono)
                    </li>
                    <li class="list-group-item">
                        <strong>Celular:</strong> @Html.DisplayFor(m => m.Celular)
                    </li>
                    <li class="list-group-item">
                        <strong>Email:</strong> @Html.DisplayFor(m => m.Email)
                    </li>
                </ul>

                <div class="mt-3">
                    <a asp-controller="Inicio" asp-action="Index" class="btn btn-dark">Volver</a>
                </div>

            </div>
        </div>
    </div>
</div>